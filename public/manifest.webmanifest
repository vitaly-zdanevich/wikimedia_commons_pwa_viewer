{
	"name": "Wikimedia Commons Viewer",
	"short_name": "Commons",
	"description": "Browse Wikimedia Commons images by category, search and location",
	"start_url": ".",
	"display": "standalone",
	"background_color": "#000",
	"theme_color": "#000",
	"icons": [
		{
			"src": "icon.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "icon-maskable.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "maskable"
		}
	]
}
